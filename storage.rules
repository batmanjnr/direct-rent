rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /conversations/{conversationId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /listings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /kyc/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Admin / God Mode access
    match /{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email.lower() == 'adeyemiakinyemi01@gmail.com' ||
        request.auth.uid == 'tR7HwQCTvJOLtnKBfKqTTzz3hw82'
      );
    }
  }
}
